postgresql:
  host: test-green-coding-postgres-container
  user: postgres
  dbname: test-green-coding
  password: testpw
  port: 9574

redis:
  host: test-green-coding-redis-container
  port: 6380

smtp:
  server: null
  sender: null
  port: null
  password: null
  user: null

admin:
  notification_email: False
  error_file: False
  error_email: False
  email_bcc: False

cluster:
  api_url: http://api.green-coding.internal:9143
  metrics_url: http://metrics.green-coding.internal:9143
  cors_allowed_origins:
    - http://api.green-coding.internal:9143
    - http://metrics.green-coding.internal:9143
  client:
    sleep_time_no_job: 300
    jobs_processing: random
    time_between_control_workload_validations: 21600
    send_control_workload_status_mail: false
    shutdown_on_job_no: false
    docker_prune: True
    full_docker_prune: False
    control_workload:
      name: Measurement control Workload
      uri: https://github.com/green-coding-solutions/measurement-control-workload
      filename: usage_scenario.yml
      branch: main
      comparison_window: 5
      threshold: 0.01
      phase: 004_[RUNTIME]
      metrics:
      - psu_energy_ac_mcp_machine
      - psu_power_ac_mcp_machine
      - cpu_power_rapl_msr_component
      - cpu_energy_rapl_msr_component

machine:
  id: 1
  description: Development machine for testing
  base_temperature_value: 10
  base_temperature_chip: "asd"
  base_temperature_feature: "asd"

  # Reservations guarantee that GMT always cpu time to execute metric providers and system does not OOM
  # Not recommended to set this in development, but when running on a cluster it should be set
  host_reserved_cpus: 1
  host_reserved_memory: 2147483648 # 2 GB

measurement:
  metric_providers:
    linux:
      cpu_utilization_procfs_system:
        sampling_rate: 99
#      disk_io_procfs_system:
#        sampling_rate: 99
      network_io_procfs_system:
        sampling_rate: 99
        remove_virtual_interfaces: True
      disk_used_statvfs_system:
        sampling_rate: 99
      memory_used_procfs_system:
        sampling_rate: 99
      cpu_utilization_cgroup_container:
        sampling_rate: 99
      memory_used_cgroup_container:
        sampling_rate: 99
      network_io_cgroup_container:
        sampling_rate: 99
    macos:
      cpu_utilization_mach_system:
        sampling_rate: 99
    common:
      psu_energy_ac_xgboost_machine:
        CPUChips: 1
        HW_CPUFreq: 3200
        CPUCores: 4
        CPUThreads: 4
        TDP: 65
        HW_MemAmountGB: 16
        Hardware_Availability_Year: 2011

sci:
  EL: 4
  RS: 1
  TE: 181000
  I: 436
  N: 0.001875

optimization:
  ignore:
    - example_optimization_test

electricity_maps_token: 'testing'
#ee_token: 'testing'

activate_scenario_runner: True
activate_eco_ci: False
activate_power_hog: False
activate_carbon_db: False
activate_ai_optimisations: False